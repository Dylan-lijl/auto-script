<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <import type="pub.carzy.auto_script.R" />

        <import type="pub.carzy.auto_script.utils.StringUtils" />
        <import type="pub.carzy.auto_script.utils.ActivityUtils" />
        <import type="java.util.concurrent.TimeUnit" />

        <import type="android.view.View" />

        <variable
            name="item"
            type="pub.carzy.auto_script.db.entity.ScriptEntity" />

        <variable
            name="multiple"
            type="androidx.databinding.ObservableBoolean" />

        <variable
            name="checkedIds"
            type="androidx.databinding.ObservableList" />
        <variable
            name="timeUtils"
            type="java.util.concurrent.TimeUnit[]" />
        <variable
            name="timeIndex"
            type="androidx.databinding.ObservableMap" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@{ checkedIds.contains(item.id)?@color/selected_blue : @color/transparent}"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <CheckBox
            android:id="@+id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="@{()->checkedIds.contains(item.id)?checkedIds.remove(item.id):checkedIds.add(item.id)}"
            android:checked="@{ checkedIds.contains(item.id)}"
            android:visibility="@{multiple?View.VISIBLE:View.GONE}" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{item.name}"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{ActivityUtils.toReadable(context,item.totalDuration+item.delayStart+item.delayEnd,TimeUnit.MILLISECONDS,timeUtils,timeIndex.get(item.id)==null?0:timeIndex.get(item.id))+context.getString(R.string.unit_ms)}" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{StringUtils.format(item.actionCount)}" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{StringUtils.formatTime(item.updateTime)}" />
            </LinearLayout>

            <LinearLayout
                android:visibility="@{StringUtils.isEmpty(item.description)?View.GONE:View.VISIBLE}"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{StringUtils.format(item.description)}" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</layout>