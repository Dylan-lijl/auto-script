                                    android:text="标题栏背景颜色" />
                            </LinearLayout>

                            <LinearLayout style="@style/fieldColorLabel">

                                <TextView
                                    style="@style/fieldColorLabel.InsideColor"
                                    android:background="@{model.proxy.currentStyle.topBarBackgroundColor}"
                                    android:text="@{MixedUtil.colorToHex(model.proxy.currentStyle.topBarBackgroundColor)}"
                                    android:textColor="@{MixedUtil.isColorLight(model.proxy.currentStyle.topBarBackgroundColor)?@color/black:@color/white}" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/top_bar_text_color_root_layout"
                            style="@style/fieldLayout">

                            <LinearLayout style="@style/fieldLeftLayout">

                                <TextView
                                    style="@style/fieldLabel"
                                    android:text="文字颜色" />

                                <TextView
                                    style="@style/fieldDescription"
                                    android:text="标题栏文字颜色" />
                            </LinearLayout>

                            <LinearLayout style="@style/fieldColorLabel">

                                <TextView
                                    style="@style/fieldColorLabel.InsideColor"
                                    android:background="@{model.proxy.currentStyle.topBarTextColor}"
                                    android:text="@{MixedUtil.colorToHex(model.proxy.currentStyle.topBarTextColor)}"
                                    android:textColor="@{MixedUtil.isColorLight(model.proxy.currentStyle.topBarTextColor)?@color/black:@color/white}" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/top_bar_image_color_root_layout"
                            style="@style/fieldLayout">

                            <LinearLayout style="@style/fieldLeftLayout">

                                <TextView
                                    style="@style/fieldLabel"
                                    android:text="图标颜色" />

                                <TextView
                                    style="@style/fieldDescription"
                                    android:text="标题栏图标颜色" />
                            </LinearLayout>

                            <LinearLayout style="@style/fieldColorLabel">

                                <TextView
                                    style="@style/fieldColorLabel.InsideColor"
                                    android:background="@{model.proxy.currentStyle.topBarImageColor}"
                                    android:text="@{MixedUtil.colorToHex(model.proxy.currentStyle.topBarImageColor)}"
                                    android:textColor="@{MixedUtil.isColorLight(model.proxy.currentStyle.topBarImageColor)?@color/black:@color/white}" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/reset_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="重置"
                                android:textColor="@color/danger" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="恢复默认配置" />
                        </LinearLayout>
                    </LinearLayout>
