                            style="@style/unitTitle"
                            android:text="标题栏"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/top_bar_background_root_layout"
                            style="@style/fieldLayout">

                            <LinearLayout style="@style/fieldLeftLayout">

                                <TextView
