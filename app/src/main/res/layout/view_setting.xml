<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="pub.carzy.auto_script.utils.MixedUtil" />

        <import type="pub.carzy.auto_script.utils.StringUtils" />

        <import type="pub.carzy.auto_script.entity.SettingProxy" />

        <import type="pub.carzy.auto_script.utils.ActivityUtils" />

        <variable
            name="model"
            type="pub.carzy.auto_script.model.SettingModel" />
    </data>

    <com.qmuiteam.qmui.widget.QMUIWindowInsetLayout2
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="@{model.proxy==null?View.INVISIBLE:View.VISIBLE}">

            <include
                android:id="@+id/top_bar_layout"
                layout="@layout/com_common_top_bar" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:visibility="@{model.proxy==null?View.INVISIBLE:View.VISIBLE}">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:orientation="vertical"
                    tools:ignore="HardcodedText">

                    <TextView
                        style="@style/unitTitle"
                        android:text="脚本设置" />

                    <LinearLayout
                        android:id="@+id/type_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="模式" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="对应录制和回放时使用的引擎,自动是优先使用root,如果不能使用则使用无障碍模式" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/type_input"
                            style="@style/fieldDropDownLabel"
                            android:text="@{model.proxy.typeString}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tick_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="时间片" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="单位是毫秒,时间片越小，手势回放越精确，但 CPU 消耗越高。默认值为 10 毫秒，建议不要设置得过大或过小。" />
                        </LinearLayout>

                        <TextView
                            style="@style/fieldInputLabel"
                            android:text="@{StringUtils.format(model.proxy.tick)+@string/unit_ms}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/auto_close_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="自动退出悬浮窗" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="停止录制并进入详情页时，自动关闭悬浮窗。" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.autoClose}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/show_operation_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="显示点按操作" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="支持显示触控位置" />
                        </LinearLayout>

                        <!--<androidx.appcompat.widget.SwitchCompat
                        android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.showOperation}" />-->
                    </LinearLayout>
                    <!--取消点按,开发者工具已经有这个功能了,自己实现麻烦且耗性能-->
                    <!--<LinearLayout
                        android:id="@+id/operation_size_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="圆点尺寸" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="设置触摸位置小圆点的半径大小" />
                        </LinearLayout>

                        <TextView
                            style="@style/fieldInputLabel"
                            android:text="@{StringUtils.format(model.proxy.operationConfig.size)}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/operation_line_width_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="边框线条" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="调整触摸位置小圆点外边框的线条粗细" />
                        </LinearLayout>

                        <TextView
                            style="@style/fieldInputLabel"
                            android:text="@{StringUtils.format(model.proxy.operationConfig.lineWidth)}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/operation_touch_color_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="激活颜色" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="设置触摸点在按下或拖动时的显示颜色" />
                        </LinearLayout>

                        <LinearLayout style="@style/fieldColorLabel">

                            <TextView
                                style="@style/fieldColorLabel.InsideColor"
                                android:background="@{model.proxy.operationConfig.touchColor}"
