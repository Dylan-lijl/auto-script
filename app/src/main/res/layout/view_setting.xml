                            <TextView
                                style="@style/fieldLabel"
                                android:text="网格线线条" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="网格线宽度" />
                        </LinearLayout>

                        <TextView
                            style="@style/fieldInputLabel"
                            android:text="@{StringUtils.format(model.proxy.maskConfig.lineWidth)}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/mask_scale_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="刻度" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="x轴和y轴坐标信息" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.maskConfig.scale}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/mask_font_color_root_layout"
                        style="@style/fieldLayout"
                        android:visibility="@{model.proxy.maskConfig.scale?View.VISIBLE:View.GONE}">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="刻度文字颜色" />

                        </LinearLayout>

                        <LinearLayout style="@style/fieldColorLabel">

                            <TextView
                                style="@style/fieldColorLabel.InsideColor"
                                android:background="@{model.proxy.maskConfig.fontColor}"
