                                android:textColor="@{MixedUtil.isColorLight(model.proxy.operationConfig.touchColor)?@color/black:@color/white}" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/operation_idle_color_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="默认颜色" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="设置触摸点在抬起时的显示颜色" />
                        </LinearLayout>

                        <LinearLayout style="@style/fieldColorLabel">

                            <TextView
                                style="@style/fieldColorLabel.InsideColor"
                                android:background="@{model.proxy.operationConfig.idleColor}"
                                android:text="@{MixedUtil.colorToHex(model.proxy.operationConfig.idleColor)}"
                                android:textColor="@{MixedUtil.isColorLight(model.proxy.operationConfig.idleColor)?@color/black:@color/white}" />
                        </LinearLayout>
                    </LinearLayout>-->

                    <TextView style="@style/dividingLine" />

                    <TextView
                        style="@style/unitTitle"
                        android:text="无障碍设置" />

                    <LinearLayout
                        android:id="@+id/auto_play_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="自动回放" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="暂停录制后关闭蒙层，并回放蒙层期间收集的手势操作。" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.autoPlay}" />
                    </LinearLayout>

                    <TextView style="@style/dividingLine" />

                    <TextView
                        style="@style/unitTitle"
                        android:text="Root设置" />

                    <LinearLayout
                        android:id="@+id/root_ignore_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="忽略悬浮窗操作手势" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="录制过程中，移除悬浮窗控制操作产生的手势。" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.ignoreFloatingScript}" />
                    </LinearLayout>

                    <TextView style="@style/dividingLine" />

                    <TextView
                        style="@style/unitTitle"
                        android:text="@string/overlay" />

                    <LinearLayout
                        android:id="@+id/float_point_root_layout"
                        style="@style/fieldLayout">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="@string/position" />

                            <TextView
                                style="@style/fieldDescription"
                                android:text="悬浮窗相对于页面内容的显示X,Y位置" />
                        </LinearLayout>

                        <TextView
                            style="@style/fieldInputLabel"
                            android:text="@{StringUtils.format(model.proxy.floatPoint.x)+','+StringUtils.format(model.proxy.floatPoint.y)}" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/float_point_update_root_layout"
