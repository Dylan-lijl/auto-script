                                    android:textColor="@{MixedUtil.isColorLight(model.proxy.currentStyle.statusBarBackgroundColor)?@color/black:@color/white}" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/status_bar_dark_root_layout"
                            style="@style/fieldLayout">

                            <LinearLayout style="@style/fieldLeftLayout">

                                <TextView
