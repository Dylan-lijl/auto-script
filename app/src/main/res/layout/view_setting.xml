                                    android:text="状态栏文字亮度（深色/浅色）" />
                            </LinearLayout>

                            <androidx.appcompat.widget.SwitchCompat
                                android:clickable="false"
                                style="@style/fieldSwitchLabel"
                                android:checked="@{model.proxy.currentStyle.statusBarMode}" />
                        </LinearLayout>
                        <!--设置标题栏背景颜色、文字颜色和图标颜色-->
