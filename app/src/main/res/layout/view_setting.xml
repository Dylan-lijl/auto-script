                        android:visibility="@{model.proxy.maskConfig.grid?View.VISIBLE:View.GONE}">

                        <LinearLayout style="@style/fieldLeftLayout">

                            <TextView
                                style="@style/fieldLabel"
                                android:text="网格线颜色" />

                        </LinearLayout>

                        <LinearLayout style="@style/fieldColorLabel">

                            <TextView
