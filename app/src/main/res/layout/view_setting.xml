                            <TextView
                                style="@style/fieldDescription"
                                android:text="打开悬浮窗会回到上次关闭时的位置" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:clickable="false"
                            style="@style/fieldSwitchLabel"
                            android:checked="@{model.proxy.dynamicUpdate}" />
                    </LinearLayout>

                    <TextView style="@style/dividingLine" />

                    <TextView
