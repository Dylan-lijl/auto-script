<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 纯文本按钮 -->
    <style name="TextButtonStyle" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@null</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:foreground">@null</item>
    </style>
    <!--透明背景按钮-->
    <style name="TransparentButton" parent="Widget.AppCompat.ImageButton">
        <!-- 完全透明背景（必须两项） -->
        <item name="android:background">@android:color/transparent</item>
        <item name="background">@android:color/transparent</item>
        <!-- 禁用自动 tint，否则图标会变蓝 -->
        <item name="android:tint">@null</item>
        <item name="tint">@null</item>
        <!-- 删除内边距 -->
        <item name="android:padding">2dp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="SimpleMenuButtonStyle" parent="Widget.AppCompat.Button">
        <!-- 去背景 -->
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <!-- 文字样式 -->
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="MenuDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#22000000</item>
        <item name="android:layout_marginVertical">4dp</item>
    </style>

    <style name="FormVerticalItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="FormLabel">
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <declare-styleable name="ActionItem">
        <attr name="android:title" format="string" />
        <attr name="android:icon" format="reference" />
        <attr name="android:hint" format="color" />
    </declare-styleable>

    <style name="unitTitle">
        <item name="android:textColor">@color/secondary</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="fieldLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="fieldLeftLayout">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingEnd">15dp</item>
    </style>

    <style name="fieldLabel">
        <item name="android:textSize">16sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="fieldDescription">
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="fieldDropDownLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical|end</item>
        <item name="android:textSize">15sp</item>
        <item name="android:drawableEnd">@drawable/expand_up_down</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="fieldInputLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical|end</item>
        <item name="android:textSize">15sp</item>
        <item name="android:drawableEnd">@drawable/arrow_right</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="fieldSwitchLabel" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:thumb">@drawable/switch_thumb</item>
        <item name="track">@drawable/switch_track</item>
        <item name="android:splitTrack">false</item>
        <!-- 去掉默认 padding -->
        <item name="trackTint">@null</item>
        <item name="thumbTint">@null</item>
        <item name="android:thumbTextPadding">8dp</item>
    </style>

    <style name="fieldColorLabel">
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:minWidth">80dp</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:background">@color/black</item>
    </style>

    <style name="fieldColorLabel.InsideColor">
        <item name="android:layout_margin">3dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="dividingLine">
        <item name="android:layout_height">2dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@color/secondary2</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>

    <style name="commonButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:background">@color/white</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="linkButton" parent="commonButton">
        <item name="android:textColor">@color/link</item>
    </style>
</resources>
